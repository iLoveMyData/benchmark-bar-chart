{
    "dataRoles": [
        {
            "name": "category",
            "kind": "Grouping",
            "displayName": "Category",
            "displayNameKey": "Role_Category"
        },
        {
            "name": "measure1",
            "kind": "Measure",
            "displayName": "Reference",
            "displayNameKey": "Role_M1",
            "requiredTypes": [{ "numeric": true }, { "integer": true }]
        },
        {
            "name": "measure2",
            "kind": "Measure",
            "displayName": "Actual",
            "displayNameKey": "Role_M2",
            "requiredTypes": [{ "numeric": true }, { "integer": true }]
        }
    ],
    "dataViewMappings": [
        {
            "conditions": [
                {
                    "category": { "max": 1 },
                    "measure1": { "max": 1 },
                    "measure2": { "max": 1 }
                }
            ],
            "categorical": {
                "categories": {
                    "for": { "in": "category" },
                    "dataReductionAlgorithm": { "top": { "count": 5000 } }
                },
                "values": {
                    "select": [
                        { "bind": { "to": "measure1" } },
                        { "bind": { "to": "measure2" } }
                    ]
                }
            }
        }
    ],
